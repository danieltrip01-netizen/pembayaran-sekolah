# ── Tambahkan ke file .env ─────────────────────────────────────────
# Sesuaikan nilai dengan data sekolah Anda

SEKOLAH_YAYASAN="Yayasan Kristen Dorkas"
SEKOLAH_NAMA_TK="TK Kristen Dorkas"
SEKOLAH_NAMA_SD="SD Kristen Dorkas"
SEKOLAH_NAMA_SMP="SMP Kristen Dorkas"

# Gunakan satu alamat untuk semua jenjang jika sama:
SEKOLAH_ALAMAT="JL. Untung Suropati No. 23 Lasem"

# Atau isi per jenjang jika berbeda:
# SEKOLAH_ALAMAT_TK="Alamat TK"
# SEKOLAH_ALAMAT_SD="Alamat SD"
# SEKOLAH_ALAMAT_SMP="Alamat SMP"

SEKOLAH_KOTA="Lasem"

KEPSEK_TK="Nama Kepala Sekolah TK"
KEPSEK_SD="Ekklesia Inezia FN, S.E, S.Pd"
KEPSEK_SMP="Nama Kepala Sekolah SMP"
